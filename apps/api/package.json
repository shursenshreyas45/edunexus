        "helmet": "^8.1.0",
        "pg": "^8.11.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.21",
        "@types/helmet": "^0.0.48",
        "@types/node": "^20.0.0",
        "@types/pg": "^8.10.9",
        "ts-node": "^10.9.1",
        "typescript": "^5.0.0"
    }
